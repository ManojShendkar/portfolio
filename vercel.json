    {
      "name": "react-monorepo",
      "buildCommand": "npm run vercel-build:react-monorepo",
      "outputDirectory": "dist/apps/react-monorepo"
    }
  ],
  "routes": [
    {
      "src": "/react-monorepo/(.*)",
